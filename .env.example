# HidroCRM - plantilla de variables de entorno
# Copia este archivo como .env.local para desarrollo o .env para produccion.
# Nunca subas .env, .env.local ni backups con secretos a repositorios.

# Base de datos PostgreSQL / Neon
# Formato: postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:<DB_PORT>/<DB_NAME>?sslmode=require
DATABASE_URL=<DATABASE_URL_POSTGRESQL>

# Superadmin de emergencia definido por entorno
SUPERADMIN_USERNAME=<USUARIO_SUPERADMIN>
SUPERADMIN_PASSWORD_HASH=<HASH_DE_PASSWORD>
SUPERADMIN_VENDEDOR=<NOMBRE_VISIBLE_SUPERADMIN>

# JWT de sesiones. Generar con:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<STRING_ALEATORIO_DE_64_CARACTERES>

# Expiracion opcional de JWT, por ejemplo 8h.
JWT_EXP=8h

# 2FA / TOTP
# Recomendado: usar una llave distinta de JWT_SECRET.
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOTP_ENCRYPTION_KEY=<STRING_ALEATORIO_DE_64_CARACTERES>
SUPERADMIN_TOTP_SECRET=

# Email transaccional legacy para reportes por correo
RESEND_API_KEY=
# Opcional: remitente verificado en Resend. Si queda vacio usa ventas@hidroperforaciones.com.
RESEND_FROM_EMAIL=

# Email de cotizaciones via Google Workspace SMTP Relay
SMTP_RELAY_HOST=smtp-relay.gmail.com
SMTP_RELAY_PORT=587
COTIZACION_NOTIFY_EMAIL=rdominguez@hidroperforaciones.com

# Cron jobs internos
CRON_SECRET=<STRING_ALEATORIO_LARGO>

# Integraciones futuras/bot
BOT_WEBHOOK_URL=
HIDRA_WEBHOOK_URL=
HIDRA_WEBHOOK_SECRET=

# MCP bot superadmin. Requerido solo si usas el token "hidra-superadmin".
# Este codigo/PIN nunca se sube a GitHub. Vive solo en .env del VPS.
HIDROCRM_MCP_APPROVAL_CODE=
# Alternativa mas segura: guardar solo SHA-256 del codigo y dejar el anterior vacio.
HIDROCRM_MCP_APPROVAL_CODE_SHA256=

# Nombre publico opcional del superadmin en UI
NEXT_PUBLIC_SUPERADMIN_NOMBRE=

# Solo para desarrollo controlado. En produccion dejar vacio/no definido.
HIDROCRM_ALLOW_SEED=

# Cotizador viejo legacy. Debe apuntar a la sub-app separada, no a la DB del CRM nuevo.
# LEGACY_APP_URL lo usa el servidor Next para montar un proxy cuando el legacy corre local/separado.
# NEXT_PUBLIC_LEGACY_APP_URL lo usa el menu.
# Ejemplos:
# LEGACY_APP_URL=http://127.0.0.1:3001
# NEXT_PUBLIC_LEGACY_APP_URL=https://<DOMINIO_PUBLICO>/legacy
LEGACY_APP_URL=
NEXT_PUBLIC_LEGACY_APP_URL=
