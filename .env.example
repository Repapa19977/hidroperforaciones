# HidroCRM - plantilla de variables de entorno
# Copia este archivo como .env.local y llena los valores reales.
# Nunca subas .env, .env.local ni backups con secretos a repos publicos.

# Base de datos PostgreSQL / Neon
# Formato: postgresql://usuario:password@host:puerto/db?sslmode=require
DATABASE_URL=<URL_DE_POSTGRESQL>

# Superadmin de emergencia definido por entorno
SUPERADMIN_USERNAME=rene
SUPERADMIN_PASSWORD_HASH=<HASH_DE_PASSWORD>
SUPERADMIN_VENDEDOR=Super Admin

# JWT de sesiones. Generar con:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<STRING_ALEATORIO_DE_64_CARACTERES>

# Expiracion opcional de JWT, por ejemplo 8h.
JWT_EXP=8h

# 2FA / TOTP
# Recomendado: usar una llave distinta de JWT_SECRET.
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOTP_ENCRYPTION_KEY=<STRING_ALEATORIO_DE_64_CARACTERES>
SUPERADMIN_TOTP_SECRET=

# Email transaccional para reportes por correo
RESEND_API_KEY=

# Cron jobs internos
CRON_SECRET=

# Integraciones futuras/bot
BOT_WEBHOOK_URL=
HIDRA_WEBHOOK_URL=
HIDRA_WEBHOOK_SECRET=

# Nombre publico opcional del superadmin en UI
NEXT_PUBLIC_SUPERADMIN_NOMBRE=

# Solo para desarrollo controlado. En produccion dejar vacio/no definido.
HIDROCRM_ALLOW_SEED=

# Cotizador viejo legacy. Debe apuntar a la sub-app separada, no a la DB del CRM nuevo.
# LEGACY_APP_URL lo usa el servidor Next para montar un proxy cuando el legacy corre local/separado.
# NEXT_PUBLIC_LEGACY_APP_URL lo usa el menu; en local puede apuntar directo al legacy de produccion.
# Ejemplos:
# LEGACY_APP_URL=http://127.0.0.1:3001
# NEXT_PUBLIC_LEGACY_APP_URL=https://hidrocrm.com/legacy
LEGACY_APP_URL=
NEXT_PUBLIC_LEGACY_APP_URL=
