generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Cotizaciones guardadas ────────────────────────────────────────────────────
model Cotizacion {
  id          String   @id @default(cuid())
  correlativo String   @unique
  cliente     String
  empresa     String   @default("")
  proyecto    String
  tipo        String // "perforacion" | "limpieza"
  estado      String   @default("borrador")
  monto       Float
  fecha       String
  vendedor    String
  datos       String   @default("{}") // JSON: QuotationData completo (para re-abrir/imprimir)
  contactoId  String? // FK a Contacto.id — opcional por backwards compat (backfill en A.1.b)
  // ── Soft delete ──
  eliminadaEn   DateTime? // null = activa, set = en papelera
  eliminadaPor  String? // username del que la borró
  motivoBorrado String? // opcional: "Error de captura", "Duplicada", etc.
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([estado])
  @@index([vendedor])
  @@index([tipo])
  @@index([vendedor, estado])
  @@index([contactoId])
  @@index([eliminadaEn])
}

// ── Historial de cambios en cotizaciones ─────────────────────────────────────
model CotizacionHistorial {
  id           String   @id @default(cuid())
  correlativo  String // FK lógica a Cotizacion.correlativo
  campo        String // campo que cambió: "estado", "monto", "datos", etc.
  valorAntes   String   @default("")
  valorDespues String   @default("")
  usuario      String   @default("") // nombre del usuario que hizo el cambio
  createdAt    DateTime @default(now())

  @@index([correlativo])
  @@index([correlativo, createdAt])
}

// ── Oportunidades del CRM ─────────────────────────────────────────────────────
model Oportunidad {
  id               String   @id @default(cuid())
  correlativo      String   @unique
  cliente          String
  empresa          String   @default("")
  monto            Float
  etapa            String // "new" | "qualified" | "proposition" | "negotiation" | "won" | "lost"
  vendedor         String
  avatar           String   @default("")
  fecha            String
  tipo             String // "Perforación" | "Limpieza Mecánica"
  profundidad      Int?
  proyecto         String   @default("")
  diasSinActividad Int      @default(0)
  contactoId       String? // FK a Contacto.id — backfill por string match en A.1.b
  // ── Soft delete ──
  eliminadaEn   DateTime?
  eliminadaPor  String?
  motivoBorrado String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([etapa])
  @@index([vendedor])
  @@index([vendedor, etapa])
  @@index([contactoId])
  @@index([eliminadaEn])
}

// ── Usuarios del sistema ──────────────────────────────────────────────────────
model Usuario {
  id           String    @id @default(cuid())
  username     String    @unique
  nombre       String // nombre del vendedor (aparece en cotizaciones y CRM)
  rol          String    @default("admin") // "admin" | "superadmin" | "cliente_final"
  passwordHash String
  activo       Boolean   @default(true)
  // Para rol "cliente_final": link al Contacto al que pertenece
  contactoId   String?
  email        String    @default("") // para magic link
  ultimoAcceso DateTime? // último login efectivo
  twoFactorEnabled       Boolean   @default(false)
  twoFactorSecret        String?
  twoFactorPendingSecret String?
  twoFactorPendingAt     DateTime?
  twoFactorConfirmedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([rol])
  @@index([contactoId])
  @@index([email])
}

// ── Contactos ─────────────────────────────────────────────────────────────────
model Contacto {
  id           String   @id @default(cuid())
  nombre       String
  alias        String   @default("") // nombre corto/apodo para búsquedas rápidas (ej. "Don Luis")
  empresa      String   @default("")
  telefono     String   @default("")
  email        String   @default("")
  tipo         String   @default("cliente") // "cliente" | "prospecto" | "proveedor"
  pais         String   @default("Guatemala")
  departamento String   @default("")
  municipio    String   @default("")
  // Nombre del proyecto asociado al contacto. Obligatorio al crearse desde el cotizador,
  // opcional al crearse desde el módulo de contactos (un contacto puede aún no tener proyecto).
  proyectoNombre String @default("")
  notas        String   @default("")
  vendedor     String // admin que creó el contacto
  // ── Soft delete ──
  eliminadoEn   DateTime?
  eliminadoPor  String?
  motivoBorrado String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([vendedor])
  @@index([tipo])
  @@index([eliminadoEn])
}

// ── Configuración del sistema (singleton) ────────────────────────────────────
model Config {
  id        String   @id @default("singleton")
  datos     String   @default("{}") // JSON: AppConfig
  updatedAt DateTime @updatedAt
}

// ── Proyectos (generados al confirmar cotización) ─────────────────────────────
model Proyecto {
  id           String          @id @default(cuid())
  correlativo  String          @unique
  cotizacionId String
  cliente      String
  empresa      String          @default("")
  nombre       String
  tipo         String
  monto        Float
  vendedor     String
  estado       String          @default("activo") // "activo" | "completado" | "pausado" | "cancelado"
  fechaInicio  String
  contactoId   String? // FK a Contacto.id — backfill por string match en A.1.b
  // Plan de pagos editable a nivel proyecto (JSON array de HitoPago). Si es null,
  // se usa el plan original de la cotización. Al editar, se congela acá.
  planPagos    String? // JSON: [{ id, label, pct, fijo }]
  // ── Portal cliente ──
  visibleParaCliente Boolean @default(true) // si el cliente puede verlo en su portal
  // ── Soft delete ──
  eliminadoEn   DateTime?
  eliminadoPor  String?
  motivoBorrado String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  entradas     BitacoraEntry[]
  pagos        Pago[]

  @@index([estado])
  @@index([vendedor])
  @@index([tipo])
  @@index([vendedor, estado])
  @@index([contactoId])
  @@index([eliminadoEn])
}

// ── Entradas diarias de la bitácora ──────────────────────────────────────────
// Liquidacion de cancelacion de proyecto confirmado.
// Guarda un snapshot separado de cotizaciones "canceladas" para no mezclar
// ventas perdidas con proyectos ya autorizados.
model ProyectoLiquidacion {
  id                  String    @id @default(cuid())
  proyectoId          String    @unique
  proyectoCorrelativo String    @default("")
  estado              String    @default("borrador") // "borrador" | "confirmada"
  fecha               String    @default("") // YYYY-MM-DD
  motivo              String    @default("")
  lineas              String    @default("[]") // JSON: LiquidacionLinea[]
  resumen             String    @default("{}") // JSON: totales al guardar/confirmar
  creadoPor           String    @default("")
  actualizadoPor      String    @default("")
  confirmadoPor       String    @default("")
  confirmadoEn        DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([proyectoCorrelativo])
  @@index([estado])
  @@index([fecha])
}

model BitacoraEntry {
  id                  String   @id @default(cuid())
  proyectoId          String
  proyecto            Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  fecha               String // "YYYY-MM-DD"
  turno               String   @default("dia") // "dia" | "noche"
  estado              String   @default("")
  tipo                String
  perforacionDia      Float    @default(0)
  ampliacion1Dia      Float    @default(0)
  ampliacion2Dia      Float    @default(0)
  rehabilitacionDia   Float    @default(0)
  perforacionTotal    Float    @default(0)
  ampliacion1Total    Float    @default(0)
  ampliacion2Total    Float    @default(0)
  rehabilitacionTotal Float    @default(0)
  horasPerforacion    Float    @default(0)
  bentonitaSacos      Float    @default(0)
  pipas               Float    @default(0)
  horasLimpieza       Float    @default(0)
  horasAforo          Float    @default(0)
  diaAdverso          Boolean  @default(false)
  notaInterna         String   @default("")
  notaCliente         String   @default("")
  // Campos nuevos del Excel DATOS BITACORA DIARIA
  diaActivo           Boolean  @default(true) // true = día activo (hubo trabajo), false = inactivo
  tubosExtraidos      Float    @default(0) // cantidad de tubos extraídos en la jornada
  diamExtraidos       String   @default("") // diámetros de tubos extraídos (ej: "8,10")
  tubosInstalados     Float    @default(0) // cantidad de tubos instalados
  diamInstalados      String   @default("") // diámetros instalados
  quimicoProducto     String   @default("") // nombre del químico usado
  quimicoCanecas      Float    @default(0) // canecas consumidas
  camareo             String   @default("") // texto libre camareo
  otrosTrabajos       String   @default("") // texto libre otros trabajos
  // Campos nuevos — formación y circulación
  formacionGeologica  String   @default("") // descripción libre (ej: "arcilla reactiva 30-45 m")
  circulacionPct      Int      @default(0)  // 0-100 en pasos de 10
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([proyectoId])
  @@index([proyectoId, fecha])
}

// ── INVENTARIO PARALELO ───────────────────────────────────────────────────────
// Producto físico que Rodrigo mantiene en reserva/stock. Fuente inicial: 30% de
// bentonita que no se entrega al cliente en cada proyecto (Fase A). Futuro:
// también pipas, grava, etc.
// El ciclo de vida:
//   1) Cotización confirmada → se crea InventarioReserva (estado: reservado)
//   2) Proyecto cerrado (bitácora 100%) → InventarioReserva pasa a estado 'disponible'
//   3) Venta externa / ajuste manual → genera MovimientoInventario
model InventarioReserva {
  id                  String   @id @default(cuid())
  proyectoId          String? // FK lógica a Proyecto (null si es reserva histórica sin proyecto)
  proyectoCorrelativo String   @default("") // correlativo para búsqueda rápida
  producto            String // "bentonita" | "pipas" | "grava" | etc.
  cantidadOriginal    Float    @default(0) // cantidad al crear la reserva
  cantidadActual      Float    @default(0) // cantidad disponible después de ventas/ajustes
  unidad              String   @default("unidad") // saco, m³, pipa, etc.
  costoUnitario       Float    @default(0) // costo al que se compró
  precioVentaSugerido Float    @default(0) // precio al que se podría revender
  estado              String   @default("reservado") // "reservado" | "disponible" | "agotado"
  fechaCreacion       String   @default("") // cuando se creó la reserva (cotización confirmada)
  fechaLiberacion     String   @default("") // cuando pasó a disponible (cierre proyecto)
  nota                String   @default("")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([proyectoId])
  @@index([producto])
  @@index([estado])
}

// Movimientos sobre el inventario: ventas externas, ajustes manuales, compras.
// Cada movimiento actualiza la cantidadActual de una InventarioReserva asociada.
model MovimientoInventario {
  id         String   @id @default(cuid())
  reservaId  String // FK lógica a InventarioReserva.id
  tipo       String // "venta_externa" | "ajuste" | "compra" | "liberacion_proyecto"
  cantidad   Float    @default(0) // positiva = entra, negativa = sale
  precioUnit Float    @default(0) // precio por unidad del movimiento
  monto      Float    @default(0) // cantidad × precioUnit (ganancia/pérdida/ajuste)
  cliente    String   @default("") // cliente externo si es venta_externa
  nota       String   @default("")
  usuario    String   @default("") // quién registró el movimiento
  createdAt  DateTime @default(now())

  @@index([reservaId])
  @@index([tipo])
  @@index([createdAt])
}

// ── Gasto extra del proyecto (Control de Gastos — tabla contable) ──────────
// Registro tipo libro de compras. Cada fila es un producto/servicio comprado
// para la ejecución del proyecto, con fecha de compra, días de crédito, y
// fecha calculada de vencimiento del pago. Se usa para alertas.
model GastoExtra {
  id              String   @id @default(cuid())
  proyectoId      String
  fecha           String             // YYYY-MM-DD — fecha de compra
  producto        String             // nombre del producto/servicio (ej "Bolsa bentonita 50kg")
  descripcion     String   @default("") // detalle más largo si se requiere
  rubro           String   @default("otro") // "combustible" | "mano-obra" | "material" | "otro"
  costoUnitario   Float    @default(0) // costo que nos cobra el proveedor (Q por unidad)
  valorUnitario   Float    @default(0) // valor de venta al cliente (referencia)
  cantidad        Float    @default(1)
  unidad          String   @default("Unidad")
  monto           Float              // cantidad × costoUnitario
  diasCredito     Int      @default(0) // 0 = contado, >0 = días para vencer
  fechaVencimiento String  @default("") // YYYY-MM-DD — fecha + diasCredito
  pagado          Boolean  @default(false) // si ya se canceló al proveedor
  proveedor       String   @default("") // nombre del proveedor (opcional)
  nota            String   @default("")
  creadoPor       String   @default("")
  createdAt       DateTime @default(now())

  // Legacy — mantener para no romper filas existentes
  concepto        String   @default("") // alias histórico de producto
  montoUnit       Float    @default(0)  // alias histórico de costoUnitario

  @@index([proyectoId])
  @@index([fecha])
  @@index([fechaVencimiento])
}

// ── Pagos recibidos por proyecto (Fase E) ──────────────────────────────────
// Cada Pago se asocia a un hitoId del plan de pagos original de la cotización.
// Si suma > monto esperado del hito, el excedente se acredita automáticamente
// al siguiente hito pendiente (lógica en el endpoint de cálculo).
model Pago {
  id                  String   @id @default(cuid())
  proyectoId          String
  proyecto            Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  proyectoCorrelativo String   @default("") // denormalizado
  hitoId              String   // 'reserva' | 'anticipo' | 'mitad-perf' | 'entubar' | 'prueba' | 'otro'
  hitoLabel           String   @default("") // snapshot del label del hito al momento
  monto               Float
  fecha               String   // YYYY-MM-DD
  metodo              String   @default("transferencia") // cheque | transferencia | deposito | efectivo | tarjeta
  referencia          String   @default("") // # cheque, ref bancaria, etc.
  nota                String   @default("")
  registradoPor       String   @default("")
  // Soft delete
  eliminadoEn         DateTime?
  eliminadoPor        String?
  motivoBorrado       String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([proyectoId])
  @@index([hitoId])
  @@index([fecha])
  @@index([eliminadoEn])
}

// ── ServiceToken — API keys para bots/integraciones (OpenClaw, webhooks, etc.) ──
// El token REAL solo se muestra al crear; en DB guardamos solo el SHA-256.
// Scopes son strings tipo "cotizaciones:read", "bitacora:write", "contactos:read".
model ServiceToken {
  id         String    @id @default(cuid())
  nombre     String    @unique // "openclaw-bot", "zapier-integration", etc.
  tokenHash  String    @unique // SHA-256 del token real
  scopes     String    @default("[]") // JSON array de scopes
  activo     Boolean   @default(true)
  ultimoUso  DateTime?
  vecesUsado Int       @default(0)
  creadoPor  String    @default("")
  notas      String    @default("")
  expiraEn   DateTime? // null = no expira
  createdAt  DateTime  @default(now())

  @@index([activo])
  @@index([tokenHash])
}

// ── AuditLog — bitácora de acciones sensibles (quién, qué, cuándo) ──
// Objetivo: saber en qué se involucra cada usuario y el bot. Útil para seguridad,
// debugging y auditorías. No es activity feed para el usuario final.
model AuditLog {
  id        String   @id @default(cuid())
  usuario   String   @default("") // nombre humano o nombre del token (bot)
  rol       String   @default("") // "admin" | "superadmin" | "bot" | "cliente_final"
  accion    String // "create" | "update" | "delete" | "restore" | "login" | "approve" | ...
  entidad   String // "cotizacion" | "contacto" | "proyecto" | "oportunidad" | ...
  entidadId String   @default("") // id del recurso afectado
  antes     String   @default("") // JSON del estado anterior (para delete/update)
  despues   String   @default("") // JSON del estado nuevo (para create/update)
  ip        String   @default("")
  userAgent String   @default("")
  createdAt DateTime @default(now())

  @@index([usuario])
  @@index([entidad, entidadId])
  @@index([createdAt])
  @@index([rol])
}

// ── MagicLink — login sin contraseña para el portal del cliente ──
// El token se manda al cliente por WhatsApp/email. TTL corto (15 min). Un solo uso.
model MagicLink {
  id        String    @id @default(cuid())
  token     String    @unique // token aleatorio largo, visible en la URL
  usuarioId String // a quién autentica (Usuario.id con rol="cliente_final")
  expiraEn  DateTime // now() + 15 min
  usadoEn   DateTime? // null = válido, set = ya usado (no re-usable)
  ip        String    @default("")
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([usuarioId])
  @@index([expiraEn])
}

// ── OportunidadAI — mensajes y recomendaciones del asistente IA por oportunidad ──
// Historia conversacional entre el asesor y el bot. El bot tiene contexto de la
// oportunidad + historial del cliente + reglas de negocio (márgenes, precio mínimo).
// Se usa en el módulo /crm como co-pilot de ventas.
model OportunidadAI {
  id            String   @id @default(cuid())
  oportunidadId String // FK lógica a Oportunidad.id
  rol           String // "asesor" | "asistente" | "sistema"
  mensaje       String // texto del mensaje
  metadata      String   @default("{}") // JSON: tokens usados, modelo, latencia, recomendación estructurada
  usuario       String   @default("") // asesor que hizo la consulta (si rol=asesor)
  createdAt     DateTime @default(now())

  @@index([oportunidadId])
  @@index([oportunidadId, createdAt])
}

// ── CuentaPorPagar — obligaciones con proveedores (independiente de proyectos) ──
// Módulo contable independiente. Lista facturas/compras pendientes de pagar a
// proveedores, con control de crédito (días) y estado pagado/vencido.
// Usa toggles de IVA/ISR como en cotizaciones para calcular el total real a pagar.
model CuentaPorPagar {
  id               String   @id @default(cuid())
  proveedor        String                 // nombre/razón social del proveedor
  nit              String   @default("")  // NIT del proveedor (opcional)
  descripcion      String                 // qué se compró/servicio
  monto            Float                  // subtotal antes de impuestos
  aplicarIva       Boolean  @default(true)
  aplicarIsr       Boolean  @default(false)
  ivaMonto         Float    @default(0)   // snapshot calculado
  isrMonto         Float    @default(0)   // snapshot calculado
  total            Float                  // monto + iva - isr (snapshot)
  fechaEmision     String                 // YYYY-MM-DD
  diasCredito      Int      @default(0)   // 0 = contado
  fechaVencimiento String                 // YYYY-MM-DD (= emision + diasCredito)
  pagado           Boolean  @default(false)
  fechaPago        String?                // YYYY-MM-DD cuando se pagó
  metodoPago       String   @default("")  // transferencia | cheque | efectivo | etc
  referenciaPago   String   @default("")  // # cheque, ref bancaria
  nota             String   @default("")
  creadoPor        String   @default("")
  // Soft delete (consistencia con Pago)
  eliminadoEn      DateTime?
  eliminadoPor     String?
  motivoBorrado    String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([proveedor])
  @@index([pagado])
  @@index([fechaVencimiento])
  @@index([eliminadoEn])
}

// ── CuentaPorCobrar — facturas pendientes de cobro (independiente de proyectos) ──
// Cliente/empresa que nos debe. Módulo independiente — no amarrado a cotizaciones
// (para eso está /proyectos/[id]/pagos). Sirve para facturas fuera de proyecto
// o para anticipos/otros cobros.
model CuentaPorCobrar {
  id               String   @id @default(cuid())
  cliente          String                 // nombre de la persona
  empresa          String   @default("")  // razón social (opcional)
  nit              String   @default("")
  descripcion      String
  monto            Float
  aplicarIva       Boolean  @default(true)
  aplicarIsr       Boolean  @default(false)
  ivaMonto         Float    @default(0)
  isrMonto         Float    @default(0)
  total            Float
  fechaEmision     String
  diasCredito      Int      @default(0)
  fechaVencimiento String
  cobrado          Boolean  @default(false)
  fechaCobro       String?
  metodoCobro      String   @default("")
  referenciaCobro  String   @default("")
  nota             String   @default("")
  creadoPor        String   @default("")
  // Soft delete
  eliminadoEn      DateTime?
  eliminadoPor     String?
  motivoBorrado    String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([cliente])
  @@index([cobrado])
  @@index([fechaVencimiento])
  @@index([eliminadoEn])
}
